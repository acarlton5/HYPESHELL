{
  "id": "system-stats",
  "name": "System Stats",
  "version": "1.0.0",
  "author": "HypeShell Core",
  "type": "module",
  "description": "Monitor CPU, Memory, and Temperature from the bar.",
  "enabledKey": "bar.modules.systemUsage.enabled",
  "settings": [
    {
      "key": "bar.modules.systemUsage.enabled",
      "type": "boolean",
      "label": "Enabled",
      "description": "Show system stats in the bar."
    },
    {
      "key": "bar.modules.systemUsage.cpuStatsEnabled",
      "type": "boolean",
      "label": "CPU Stats",
      "description": "Monitor CPU usage percentage."
    },
    {
      "key": "bar.modules.systemUsage.memoryStatsEnabled",
      "type": "boolean",
      "label": "Memory Stats",
      "description": "Monitor RAM usage."
    },
    {
      "key": "bar.modules.systemUsage.tempStatsEnabled",
      "type": "boolean",
      "label": "Temperature",
      "description": "Monitor CPU temperature."
    }
  ]
}
